{
  "name": "corridor-price-updater",
  "version": "1.0.0",
  "description": "Real-time NGN/USD price updater for Corridor Hook",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "dev:watch": "nodemon --watch src --exec ts-node src/index.ts"
  },
