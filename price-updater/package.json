    "axios": "^1.6.7",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2",
    "nodemon": "^3.1.0"
  }
}
